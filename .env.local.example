# ────────────────────────────────────────────────────────
# Supabase
# ────────────────────────────────────────────────────────
# Server-side (RLS bypass — keep secret).
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Browser-side (safe to ship to the client).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ────────────────────────────────────────────────────────
# Resend (transactional + daily WoW email)
# ────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=Fab Four Academy <notifications@fabfouracademy.com>

# Comma-separated list of inboxes that receive new-inquiry notifications.
ADMIN_EMAILS=dan@fabfouracademy.com

# ────────────────────────────────────────────────────────
# Admin dashboard
# ────────────────────────────────────────────────────────
# Password for HTTP basic auth on /admin/*. Username is ignored.
ADMIN_PASSWORD=

# ────────────────────────────────────────────────────────
# Cron
# ────────────────────────────────────────────────────────
# Shared secret between Vercel Cron and the cron route handler.
# Vercel Cron sends `Authorization: Bearer $CRON_SECRET` on every fire.
# Generate with: openssl rand -base64 32 | tr -d '=+/' | head -c 32
CRON_SECRET=

# ────────────────────────────────────────────────────────
# Site
# ────────────────────────────────────────────────────────
# Used in email CTAs and unsubscribe links. Set to your dev origin
# (http://localhost:3000) when iterating, or the production domain.
SITE_URL=https://fabfouracademy.com
